{
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier . --write --cache --ignore-unknown",
    "format:check": "prettier . --check --cache --ignore-unknown"
  },
  "lint-staged": {
    "*.{html,css,js,jsx,ts,tsx,json,md,yml,yaml}": "prettier --write"
  }
}
